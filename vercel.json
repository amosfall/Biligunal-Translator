{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }],
  "functions": {
    "api/translate-stream.ts": {
      "maxDuration": 300,
      "includeFiles": "lib/**"
    },
    "api/translate.ts": {
      "maxDuration": 300,
      "includeFiles": "lib/**"
    },
    "api/text-followup.ts": { "maxDuration": 120 },
    "api/refine-zh.ts": {
      "maxDuration": 120,
      "includeFiles": "lib/**"
    }
  }
}
