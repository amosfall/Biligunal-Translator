# DeepSeek API Key (https://platform.deepseek.com/api_keys)
# 复制本文件为 .env.local 后填写你的密钥
DEEPSEEK_API_KEY=

# Neon 数据库连接串（可选，用于多设备历史同步）
# 本地开发：从 Vercel 项目 Storage 复制 DATABASE_URL 到 .env.local
# Vercel 部署：添加 Neon 集成后自动注入
# DATABASE_URL=
#
# 一次性把旧本地用户名对应的历史合并到新 Clerk 账号（Neon）：
# MERGE_TO_CLERK_USER_ID=user_xxx npm run merge-history
# MERGE_FROM_USERNAME=Aki   （可选，默认 Aki）

# Translator API server port (optional, default 8787)
PORT=8787

# ── Clerk（可选，与已有 Clerk 应用共用同一套 Key 即合并用户池）──
# 前端：从 Clerk Dashboard → API Keys 复制 Publishable key
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# 服务端 / Vercel：同一应用的 Secret key（切勿提交到 git）
# CLERK_SECRET_KEY=sk_test_...
# 在 Clerk 中为应用添加登录方式：Email、Username+密码等；并加入本机与生产 URL（如 http://localhost:3000）
#
# 历史 API 管理员（Clerk User ID，逗号分隔）：可拉取/删除库内全部翻译记录
# CLERK_ADMIN_USER_IDS=user_39N3O9Fuuplb1cdcVqI7oZkTlmK
# 须与上一致，侧栏才会列出全部（构建时注入）
# VITE_CLERK_ADMIN_USER_IDS=user_39N3O9Fuuplb1cdcVqI7oZkTlmK
